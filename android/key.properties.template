# Copia este archivo como android/key.properties y rellena los valores reales.
# IMPORTANTE: key.properties está en .gitignore — NUNCA lo subas a GitHub.
#
# Para generar el keystore:
#   keytool -genkey -v -keystore kakeibopro-release.jks \
#           -alias kakeibopro -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=../kakeibopro-release.jks
storePassword=TU_STORE_PASSWORD
keyAlias=kakeibopro
keyPassword=TU_KEY_PASSWORD
